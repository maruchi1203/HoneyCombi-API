  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start:dev": "tsc-watch -p tsconfig.dev.json --watchFile fixedpollinginterval --watchDirectory fixedpollinginterval --preserveWatchOutput --onSuccess \"node dist/main.js\"",
    "start:dev:docker": "tsc-watch -p tsconfig.dev.json --watchFile fixedpollinginterval --watchDirectory fixedpollinginterval --preserveWatchOutput --onSuccess \"node dist/main.js\"",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint:test": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --config ./test/jest.json",
    "test:watch": "jest --config ./test/jest.json --watch",
    "test:cov": "jest --config ./test/jest.json --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config ./test/jest.json --runInBand",
    "test:e2e": "jest --config ./test/jest.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.760.0",
    "@aws-sdk/s3-request-presigner": "^3.760.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/typeorm": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "firebase-admin": "^12.7.0",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.24"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.6",
    "@types/express": "^5.0.0",
    "@types/gapi": "^0.0.47",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsc-watch": "^7.2.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.0",
    "file-type": "^21.0.0",
    "fast-xml-parser": "^5.3.4",
    "ajv": "^8.18.0",
    "minimatch": "^10.2.1"
  }
